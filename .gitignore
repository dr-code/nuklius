# Workaround for Nx bug: parent .gitignore files with '*' can cause
# `nx show projects` to return nothing by ignoring subprojects.
# See: https://github.com/nrwl/nx/issues/27368
# Unignore everything to ensure Nx detects all projects
!*

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
secrets.json
credentials.json
service-account.json

# ─── Claude Code personal overrides ──────────────────────────────────────────
CLAUDE.local.md
.claude/settings.local.json

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules

# ─── Build output ─────────────────────────────────────────────────────────────
dist
tmp
out-tsc
build
.next
out
app-out

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage
.nyc_output/
test-results/
playwright-report/
test-output

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/settings.json
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.swp
*.swo
*~

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log
yarn-debug.log*
yarn-error.log*
testem.log
/libpeerconnection.log

# ─── Nx ───────────────────────────────────────────────────────────────────────
.nx/cache
.nx/workspace-data

# ─── Vite / Vitest ────────────────────────────────────────────────────────────
vite.config.*.timestamp*
vitest.config.*.timestamp*
.rollup.cache

# ─── Trilium app data ─────────────────────────────────────────────────────────
apps/*/data
apps/*/out
upload
/result
.svelte-kit

# ─── Nuklius runtime databases ────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ─── Tessera graph and session state ──────────────────────────────────────────
.tessera/

# ─── CI smoke logs ────────────────────────────────────────────────────────────
logs/
smoke-logs/

# ─── Security scan reports (uploaded as CI artifacts, not committed) ──────────
security-reports/
sarif-results/

# ─── pnpm store ───────────────────────────────────────────────────────────────
.pnpm-store/

# ─── Temporary / research ─────────────────────────────────────────────────────
_ai_temp/
.mdd/
*.bak
*.tmp
/connect.lock
/typings
/.sass-cache
